{
    "ko": {
        "weather": {
            "bad": {
                "condition": "['RAINY', 'STORM'].includes(status)",
                "actions": [
                    {
                        "type": "EMOTION",
                        "alias": "sad"
                    },
                    {
                        "type": "MOTION",
                        "alias": "idle"
                    }
                ]
            },
            "good": {
                "condition": "status === 'SUNNY'",
                "actions": [
                    {
                        "type": "EVENT",
                        "value": "HAPPY_DANCE",
                        "duration": 5000
                    },
                    {
                        "type": "EMOTION",
                        "alias": "joy"
                    }
                ]
            }
        }
    },
