{
    "ko": {
        "youtube": {
            "playing": {
                "condition": "state === 'PLAYING'",
                "actions": [
                    {
                        "type": "EVENT",
                        "value": "MUSIC_START"
                    }
                ]
            },
            "stopped": {
                "condition": "['PAUSED', 'ENDED'].includes(state)",
                "actions": [
                    {
                        "type": "EVENT",
                        "value": "MUSIC_STOP"
                    }
                ]
            }
        }
    },
