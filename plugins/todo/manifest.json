{
    "id": "todo",
    "name": "일 관리",
    "version": "1.0.0",
    "author": "AEGIS Core",
    "entry": {
        "html": "assets/widget.html",
        "js": "assets/widget.js",
        "css": "assets/widget.css",
        "backend": "router.py"
    },
    "permissions": [
        "api.google_suite",
        "api.briefing_scheduler"
    ],
    "layout": {
        "default_size": "size-2"
    },
    "icon": "✅",
    "actions": [
        {
            "id": "add",
            "commands": [
                "추가",
                "등록",
                "add",
                "a"
            ],
            "params": [
                "text"
            ],
            "desc": "Add a new task"
        },
        {
            "id": "done",
            "commands": [
                "완료",
                "끝",
                "done",
                "complete",
                "c",
                "d"
            ],
            "params": [
                "title"
            ],
            "desc": "Complete a task"
        },
        {
            "id": "list",
            "commands": [
                "목록",
                "list",
                "ls",
                "l",
                "요약",
                "briefing",
                "b"
            ],
            "params": [],
            "desc": "Show all tasks"
        }
    ]
}