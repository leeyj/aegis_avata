{
    "id": "notion",
    "name": "노션 지능형 지식 허브",
    "version": "1.0.0",
    "author": "AEGIS Core",
    "entry": {
        "html": "assets/widget.html",
        "js": "assets/widget.js",
        "css": "assets/widget.css",
        "backend": "router.py"
    },
    "permissions": [
        "api.notion",
        "api.ai_gateway",
        "api.briefing_scheduler"
    ],
    "layout": {
        "default_size": "size-2"
    },
    "exports": {
        "commands": [
            {
                "prefix": "/ns",
                "name": "노션 제어",
                "examples": [
                    "/ns clean",
                    "/ns switch @업무",
                    "/ns search 키워드"
                ]
            },
            {
                "prefix": "/memo",
                "name": "노션 메모 추가",
                "examples": [
                    "/memo 오늘 할일 정리"
                ]
            }
        ]
    }
}